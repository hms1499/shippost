# Contract addresses — Celo Sepolia testnet (chainId 11142220)
NEXT_PUBLIC_PAYMENT_CONTRACT_TESTNET=0x277e140933d600cafcad38e2f1018e4fbd5476b2
NEXT_PUBLIC_AGENT_WALLET_TESTNET=0x7538627c5eef2193fa4960f03157f482eca333be

# Contract addresses — Celo Mainnet (filled in Week 2)
NEXT_PUBLIC_PAYMENT_CONTRACT_MAINNET=
